# ── Supabase (auth + Postgres) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── AI providers (optional — mock used if none set) ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GEMINI_API_KEY=
AI_DEFAULT_PROVIDER=mock

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Rate limiting (optional Upstash; in-memory fallback) ──
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Billing: Tap Payments (GCC) ──
# Live/sandbox secret key (sk_test_... or sk_live_...). Server-only.
TAP_SECRET_KEY=
# HMAC secret for verifying Tap webhooks (set the same value in the Tap dashboard).
TAP_WEBHOOK_SECRET=
# Optional: webhook replay tolerance in ms (default 300000 = 5 min).
TAP_WEBHOOK_TOLERANCE_MS=300000

# ── Store credential encryption ──
# 32+ char secret used to encrypt connected-store API credentials at rest
# (AES-256-GCM). Generate one with:  openssl rand -base64 32
# If unset, live store connections still work but credentials are NOT saved
# (you'd re-enter them to re-sync). Set this on Railway to enable re-sync.
CREDENTIALS_ENCRYPTION_KEY=
